# Application
DEBUG=false

# Database
POSTGRES_USER=hnd_user
POSTGRES_PASSWORD=hnd_password
POSTGRES_DB=hnd_db
DATABASE_URL=postgresql+asyncpg://hnd_user:hnd_password@localhost:5432/hnd_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# LLM Configuration
LLM_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small

# Vector Search
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K_CHUNKS=5

# RSS Ingestion
RSS_FETCH_INTERVAL_MINUTES=60
REQUEST_TIMEOUT_SECONDS=30
USER_AGENT=HND-Bot/1.0 (+https://github.com/charkelham/Humanitarian-News-Dashboard)

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
